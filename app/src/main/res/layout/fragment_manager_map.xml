<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/addMarkerButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Add Marker" />

    <TextView
        android:id="@+id/mapStatusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap Add Marker, enter a stop name, then tap the map to place it. Tap an existing marker to rename, move, or delete it."
        android:textSize="14sp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp" />

    <FrameLayout
        android:id="@+id/managerMapContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>